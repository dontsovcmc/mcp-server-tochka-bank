{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.dontsovcmc/tochka-bank",
  "description": "MCP server for Tochka Bank API — balance, payments, invoices, UPD, payment tracking",
  "repository": {
    "url": "https://github.com/dontsovcmc/mcp-server-tochka-bank",
    "source": "github"
  },
  "version": "0.3.2",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "mcp-server-tochka-bank",
      "version": "0.3.2",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "uvx",
      "environmentVariables": [
        {
          "name": "TOCHKA_TOKEN",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
